<Window x:Class="TodoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:TodoApp.Presentation.Converters"
        mc:Ignorable="d"
        Title="할일 관리" Height="550" Width="850"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToStrikethroughConverter x:Key="StrikethroughConverter"/>
        <converters:PriorityToColorConverter x:Key="PriorityColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽: 할일 목록 -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="할일 목록" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

            <!-- 필터 버튼 -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="전체" Command="{Binding TodoList.SetFilterCommand}" CommandParameter="All"
                        Padding="12,6" Margin="0,0,4,0"/>
                <Button Content="미완료" Command="{Binding TodoList.SetFilterCommand}" CommandParameter="Pending"
                        Padding="12,6" Margin="0,0,4,0"/>
                <Button Content="완료" Command="{Binding TodoList.SetFilterCommand}" CommandParameter="Completed"
                        Padding="12,6" Margin="0,0,4,0"/>
            </StackPanel>

            <!-- 오류 메시지 -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 할일 리스트 -->
            <ListBox ItemsSource="{Binding TodoList.FilteredItems}"
                     SelectedItem="{Binding TodoList.SelectedItem}"
                     HorizontalContentAlignment="Stretch"
                     BorderThickness="1" BorderBrush="#DDD">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- 체크박스 -->
                            <CheckBox Grid.Column="0" Grid.RowSpan="2" VerticalAlignment="Center" Margin="0,0,8,0"
                                      IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                      Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>

                            <!-- 우선순위 색상 표시 -->
                            <Ellipse Grid.Column="1" Grid.RowSpan="2" Width="12" Height="12"
                                     Fill="{Binding Priority, Converter={StaticResource PriorityColorConverter}}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>

                            <!-- 제목 -->
                            <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding Title}"
                                       FontSize="14" FontWeight="SemiBold"
                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource StrikethroughConverter}}"/>

                            <!-- 마감일 + 초과 경고 -->
                            <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding DueDateText}" Foreground="Gray" FontSize="11" Margin="0,2,8,0"/>
                                <TextBlock Text="⚠ 마감 초과!" Foreground="Red" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"
                                           Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- 오른쪽: 편집 폼 -->
        <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="16" Margin="8,0,0,0">
            <DockPanel>
                <!-- 제목 (추가/수정 모드에 따라 변경) -->
                <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,16">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="새 할일 추가"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor.IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="할일 수정"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 버튼 영역 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <!-- 추가 버튼: 수정 모드가 아닐 때만 표시 -->
                    <Button Content="추가" Command="{Binding AddCommand}" Padding="8,6" Margin="0,0,0,4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Editor.IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 수정 저장 버튼: 수정 모드일 때만 표시 -->
                    <Button Content="수정 저장" Command="{Binding UpdateCommand}" Padding="8,6" Margin="0,0,0,4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Editor.IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="선택 항목 편집" Command="{Binding EditCommand}" Padding="8,6" Margin="0,0,0,4"/>
                    <Button Content="삭제" Command="{Binding DeleteCommand}" Padding="8,6" Margin="0,0,0,4" Foreground="Red"/>
                    <Button Content="취소" Command="{Binding CancelCommand}" Padding="8,6"/>
                </StackPanel>

                <!-- 입력 폼 -->
                <StackPanel>
                    <TextBlock Text="제목" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Editor.Title, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,0,12"/>

                    <TextBlock Text="설명" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Editor.Description, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" Margin="0,0,0,12" AcceptsReturn="True" Height="60"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="우선순위" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Editor.PriorityOptions}"
                              SelectedItem="{Binding Editor.SelectedPriority}"
                              Padding="6,4" Margin="0,0,0,12"/>

                    <TextBlock Text="마감일" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding Editor.DueDate}" Margin="0,0,0,12"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
